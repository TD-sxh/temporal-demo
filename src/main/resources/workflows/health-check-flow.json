{
  "id": "health-check-flow",
  "name": "Health Check Workflow",
  "version": 1,
  "startNode": "__start__",
  "initialVariables": {
    "maxFollowUps": 5,
    "followUpCount": 0,
    "currentScore": 0.0,
    "severity": "NORMAL"
  },
  "nodes": [
    {
      "id": "__start__",
      "name": "Start",
      "type": "START",
      "next": "record_visit"
    },
    {
      "id": "record_visit",
      "name": "Record Patient Visit",
      "type": "TASK",
      "activityName": "recordVisit",
      "input": {
        "patientId": "#patientId",
        "patientName": "#patientName",
        "doctorName": "#doctorName",
        "visitReason": "#visitReason"
      },
      "outputKey": "visitId",
      "next": "get_diagnosis"
    },
    {
      "id": "get_diagnosis",
      "name": "Get Diagnosis Results",
      "type": "TASK",
      "activityName": "getDiagnosisResult",
      "input": {
        "patientId": "#patientId",
        "scenario": "#scenario"
      },
      "outputKey": {
        "diagnosis": "*",
        "diagCode": "code",
        "diagScore": "score",
        "diagDescription": "description"
      },
      "next": "analyze_results"
    },
    {
      "id": "analyze_results",
      "name": "Analyze Results",
      "type": "TASK",
      "activityName": "analyzeResults",
      "input": {
        "diagnosis": "#diagnosis"
      },
      "outputKey": "severity",
      "next": "check_severe"
    },
    {
      "id": "check_severe",
      "name": "Check if Severe",
      "type": "BRANCH",
      "branches": [
        {
          "condition": "#severity == 'SEVERE'",
          "next": "parallel_notify"
        }
      ],
      "defaultNext": "delay_before_loop"
    },
    {
      "id": "parallel_notify",
      "name": "Parallel Notify (Email + SMS)",
      "type": "PARALLEL",
      "parallelBranches": [
        {
          "branchId": "email",
          "nodes": [
            {
              "id": "send_email",
              "name": "Send Email Notification",
              "type": "TASK",
              "activityName": "sendEmail",
              "input": {
                "doctorName": "#doctorName",
                "patientId": "#patientId",
                "diagnosis": "#diagnosis"
              },
              "outputKey": {
                "emailResult": "*",
                "emailStatus": "status"
              }
            }
          ]
        },
        {
          "branchId": "sms",
          "nodes": [
            {
              "id": "send_sms",
              "name": "Send SMS Notification",
              "type": "TASK",
              "activityName": "sendSms",
              "input": {
                "doctorName": "#doctorName",
                "patientId": "#patientId",
                "severity": "#severity"
              },
              "outputKey": {
                "smsResult": "*",
                "smsStatus": "status"
              }
            }
          ]
        }
      ],
      "next": "delay_before_loop"
    },
    {
      "id": "delay_before_loop",
      "name": "Brief Pause Before Follow-Up",
      "type": "DELAY",
      "delaySeconds": 5,
      "next": "follow_up_loop"
    },
    {
      "id": "follow_up_loop",
      "name": "Follow-Up Loop",
      "type": "LOOP",
      "condition": "#followUpCount < #maxFollowUps",
      "maxIterations": 20,
      "loopBody": [
        {
          "id": "wait_interval",
          "name": "Wait for interval or signal",
          "type": "WAIT",
          "signalName": "labResult",
          "timeoutSeconds": 20,
          "outputKey": "labSignal",
          "timeoutNext": null,
          "next": null
        },
        {
          "id": "process_signal",
          "name": "Process Lab Signal if present",
          "type": "TASK",
          "activityName": "processLabSignal",
          "input": {
            "labSignal": "#labSignal",
            "currentScore": "#currentScore"
          },
          "outputKey": "currentScore",
          "next": null
        },
        {
          "id": "perform_follow_up",
          "name": "Perform Follow-Up",
          "type": "TASK",
          "activityName": "performFollowUp",
          "input": {
            "patientId": "#patientId",
            "followUpCount": "#followUpCount",
            "severity": "#severity",
            "currentScore": "#currentScore"
          },
          "outputKey": {
            "followUpResult": "*",
            "healthScore": "healthScore"
          },
          "next": null
        },
        {
          "id": "update_counters",
          "name": "Update follow-up counters",
          "type": "TASK",
          "activityName": "updateFollowUpState",
          "input": {
            "followUpResult": "#followUpResult",
            "followUpCount": "#followUpCount"
          },
          "outputKey": {
            "followUpCount": "followUpCount",
            "currentScore": "currentScore",
            "severity": "severity"
          },
          "next": null
        }
      ],
      "next": "build_summary"
    },
    {
      "id": "build_summary",
      "name": "Build Summary",
      "type": "TASK",
      "activityName": "buildSummary",
      "input": {
        "patientId": "#patientId",
        "severity": "#severity",
        "followUpCount": "#followUpCount",
        "visitId": "#visitId"
      },
      "outputKey": "summary",
      "next": "__end__"
    },
    {
      "id": "__end__",
      "name": "End",
      "type": "END"
    }
  ]
}
